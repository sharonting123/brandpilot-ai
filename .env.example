SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
# Set false if all Supabase writes move behind server-side APIs.
SUPABASE_BROWSER_ENABLED=true

# OpenAI-compatible model API. Use either MODEL_API_KEY or OPENAI_API_KEY.
OPENAI_API_KEY=your-model-api-key
OPENAI_MODEL=gpt-4o-mini

# Optional: point to another OpenAI-compatible gateway.
# DeepSeek OpenAI-compatible example:
# MODEL_API_BASE_URL=https://api.deepseek.com/v1
# MODEL_API_KEY=your-model-api-key
# MODEL_NAME=deepseek-v4-pro
# MODEL_MAX_TOKENS=4096

# Production runtime controls.
NODE_ENV=production
HOST=127.0.0.1
PORT=4173
MODEL_TIMEOUT_MS=55000
SUPABASE_TIMEOUT_MS=5000
AGENT_RATE_LIMIT_PER_MINUTE=12

# 阿里云百炼 DashScope（数字人：Qwen-TTS + wan2.2-s2v 对口型）
# 在百炼控制台创建 API Key，地域选华北2（北京）
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
# 可选：自定义数字人参考人像（公网可访问图片 URL）
DIGITAL_HUMAN_AVATAR_URL=https://www.brdpilot.com/assets/digital-human-anchor.jpg
# DASHSCOPE_TTS_MODEL=qwen3-tts-flash
# DASHSCOPE_TTS_VOICE=Serena
# DASHSCOPE_S2V_MODEL=wan2.2-s2v
# DASHSCOPE_S2V_RESOLUTION=480P
# DASHSCOPE_TIMEOUT_MS=120000
