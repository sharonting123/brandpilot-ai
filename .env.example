SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
# 服务端专用：用户/会话/消息表读写（不可暴露到浏览器）
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# 登录 JWT 签名密钥（生产务必设置长随机串；未设置时回退 service role key）
AUTH_SECRET=your-long-random-auth-secret
# Set false if all Supabase writes move behind server-side APIs.
SUPABASE_BROWSER_ENABLED=true

# 主模型：美团 LongCat OpenAI 兼容接口（对话 / Agent / NL2SQL 等）
MODEL_API_BASE_URL=https://api.longcat.chat/openai
MODEL_API_KEY=your-longcat-api-key
MODEL_NAME=LongCat-2.0
# 可与主模型共用同一 Key
# LONGCAT_API_KEY=your-longcat-api-key
# LONGCAT_API_BASE_URL=https://api.longcat.chat/openai
# 可选：结构化提取专用模型（默认与主模型同为 LongCat-2.0）
# MODEL_STRUCTURED_NAME=LongCat-2.0
# MODEL_STRUCTURED_API_KEY=your-longcat-api-key
# MODEL_STRUCTURED_API_BASE_URL=https://api.longcat.chat/openai
# MODEL_MAX_TOKENS=8192

# Production runtime controls.
NODE_ENV=production
HOST=127.0.0.1
PORT=4173
MODEL_TIMEOUT_MS=240000
SUPABASE_TIMEOUT_MS=5000
AGENT_RATE_LIMIT_PER_MINUTE=12

# 阿里云百炼 DashScope（RAG Embedding / Rerank，与下方 RAG 配置共用）
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# 图片 OCR（默认美团 LongCat 多模态；可改 OCR_PROVIDER=dashscope 走百炼 qwen-vl-ocr）
# OCR_PROVIDER=longcat
# LONGCAT_API_KEY=your-longcat-api-key
# OCR_API_BASE_URL=https://api.longcat.chat/openai
# OCR_MODEL=LongCat-2.0
# OCR_TIMEOUT_MS=90000

# RAG：Embedding 向量召回 + Rerank 精排（默认走百炼 DashScope，与 DASHSCOPE_API_KEY 共用）
# RAG_EMBEDDING_ENABLED=true
# RAG_RERANK_ENABLED=true
# RAG_EMBEDDING_PROVIDER=auto
# RAG_EMBEDDING_MODEL=text-embedding-v3
# RAG_RERANK_MODEL=gte-rerank-v2
# 可选：高德地图 Web JS API Key（配置后商圈地图走官方 SDK）
# AMAP_WEB_KEY=your-amap-web-key

# 外部 Agent 侧车（BrandPilot 保留 7 Agent，报告生成走侧车工具服务）
# 启动侧车 Python 工具服务后设为 true；/api/agent-run 会自动尝试生成 HTML 报告
SIDECAR_ENABLED=false
SIDECAR_REPORT_ENABLED=true
SIDECAR_TOOL_URL=http://127.0.0.1:1601
SIDECAR_BACKEND_URL=http://127.0.0.1:8080
# 侧车 Python 工具服务目录（指向 /home/ubuntu/agent 项目中的 tool 服务目录）
# SIDECAR_TOOL_DIR=/path/to/agent-tool-service
SIDECAR_REPORT_FILE_TYPE=html
SIDECAR_TEMPLATE_TYPE=fix
SIDECAR_TIMEOUT_MS=120000
