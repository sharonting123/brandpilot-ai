SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# OpenAI-compatible model API. Use either MODEL_API_KEY or OPENAI_API_KEY.
OPENAI_API_KEY=your-model-api-key
OPENAI_MODEL=gpt-4o-mini

# Optional: point to another OpenAI-compatible gateway.
# DeepSeek OpenAI-compatible example:
# MODEL_API_BASE_URL=https://api.deepseek.com/v1
# MODEL_API_KEY=your-model-api-key
# MODEL_NAME=deepseek-v4-pro
# MODEL_MAX_TOKENS=4096
