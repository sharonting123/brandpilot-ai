{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/chat.js": {
      "maxDuration": 60
    },
    "api/agent-run.js": {
      "maxDuration": 60
    },
    "api/events.js": {
      "maxDuration": 10
    },
    "api/digital-human.js": {
      "maxDuration": 120
    },
    "api/health.js": {
      "maxDuration": 10
    },
    "api/config.js": {
      "maxDuration": 5
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
